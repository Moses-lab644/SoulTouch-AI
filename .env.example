# Decor AI Bot — Environment Variables
# Set these in Railway's Variables tab (NOT committed to git)

# Required — get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN

# Required — your personal Telegram user ID (integer)
# Get it from @userinfobot on Telegram
ADMIN_TELEGRAM_ID=

# Optional — path to SQLite database file
# Railway provides persistent storage; default path works fine
# DB_PATH=/data/bot.db
